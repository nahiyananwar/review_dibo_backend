# ============================================================
# Review Dibo API - Environment configuration (example)
# Copy this file to `.env` and adjust the values for your setup.
# ============================================================

# ---- Application ----
APP_NAME=Review Dibo API
APP_ENV=development
HOST=0.0.0.0
PORT=8011

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/review_dibo

# ---- Auth / JWT ----
# Generate a strong secret, e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS (comma-separated list of allowed origins) ----
CORS_ORIGINS=http://localhost:3000

# ---- Moderation ----
# true: registered members are auto-approved, guest reviews are held for review.
# false: ALL reviews require moderator/admin approval before they appear.
REVIEW_AUTO_APPROVE=true
# Dev convenience only — return the password-reset token in the API response so
# the flow can be tested without an email service. MUST stay false in production.
AUTH_DEV_RETURN_RESET_TOKEN=false

# ---- Seed data (used by `python seed.py`) ----
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@reviewdibo.com
SEED_ADMIN_PASSWORD=admin12345
