# ============================================================
# Review Dibo API - Environment configuration (example)
# Copy this file to `.env` and adjust the values for your setup.
# ============================================================

# ---- Application ----
APP_NAME=Review Dibo API
APP_ENV=development
HOST=0.0.0.0
PORT=8011

# ---- Database (PostgreSQL) ----
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/review_dibo

# ---- Auth / JWT ----
# Generate a strong secret, e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS (comma-separated list of allowed origins) ----
CORS_ORIGINS=http://localhost:3000

# ---- Seed data (used by `python seed.py`) ----
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@reviewdibo.local
SEED_ADMIN_PASSWORD=admin12345
